/* ---- pywal themed rofi config ---- */
/* Rofi Config for Google Search      */

@import "~/.config/rofi/config.rasi"

/* ---- Window ---- */
window {
    width: 40%;
    y-offset: 6px;
    location: north;
}

/* ---- Inputbar ---- */
inputbar {
    enabled: true;
}

/* ---- Mainbox ---- */
mainbox {
    padding: 0px;
    children: [ "entry"];
}

/* ---- Entry ---- */
entry {
    placeholder: "🔎 Google Search";
}
